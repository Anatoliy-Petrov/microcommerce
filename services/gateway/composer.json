{
    "name": "microcommerce/gateway",
    "description": "API Gateway — JWT validation and request proxying",
    "type": "project",
    "require": {
        "php": "^8.3",
        "symfony/console": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/yaml": "^7.0",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true
        },
        "platform": {
            "php": "8.3"
        },
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    },
    "scripts": {},
    "minimum-stability": "stable",
    "prefer-stable": true
}