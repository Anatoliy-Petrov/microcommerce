APP_NAME=NotificationService
APP_ENV=local
APP_KEY=base64:CHANGE_ME
APP_DEBUG=true
APP_URL=http://localhost:8007

DB_CONNECTION=mysql
DB_HOST=mysql-notification
DB_PORT=3306
DB_DATABASE=notification_db
DB_USERNAME=notification_user
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=phpredis

RABBITMQ_URL=amqp://rabbit:rabbit@rabbitmq:5672

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@microcommerce.test
MAIL_FROM_NAME="${APP_NAME}"

SMS_DRIVER=vonage
VONAGE_KEY=CHANGE_ME
VONAGE_SECRET=CHANGE_ME
VONAGE_SMS_FROM=MICROCOMMERCE

QUEUE_CONNECTION=rabbitmq
CACHE_DRIVER=redis