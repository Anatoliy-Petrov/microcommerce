{
    "name": "microcommerce/php-common",
    "description": "Shared DTOs and RabbitMQ helpers for the microcommerce platform",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "Microcommerce\\Common\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Microcommerce\\Common\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}