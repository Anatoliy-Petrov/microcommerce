# ── Service Ports (host-side) ────────────────────────────────────
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
CATALOG_SERVICE_PORT=8003
CART_SERVICE_PORT=8004
ORDER_SERVICE_PORT=8005
PAYMENT_SERVICE_PORT=8006
NOTIFICATION_SERVICE_PORT=8007
ANALYTICS_SERVICE_PORT=8008

RABBITMQ_MANAGEMENT_PORT=15672
ELASTICSEARCH_PORT=9200

# ── MySQL passwords (one per service DB) ─────────────────────────
AUTH_DB_PASSWORD=secret
USER_DB_PASSWORD=secret
CATALOG_DB_PASSWORD=secret
ORDER_DB_PASSWORD=secret
PAYMENT_DB_PASSWORD=secret
NOTIFICATION_DB_PASSWORD=secret
ANALYTICS_DB_PASSWORD=secret

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── RabbitMQ ──────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=rabbit
RABBITMQ_DEFAULT_PASS=rabbit

# ── Elasticsearch ─────────────────────────────────────────────────
ELASTIC_PASSWORD=changeme